### 4. **预加载和缓存策略**

```javascript
class FaviconCache {
  constructor() {
    this.cache = new Map();
    this.pending = new Map();
  }
  
  async get(url) {
    const hostname = new URL(url).hostname;
    
    // 检查内存缓存
    if (this.cache.has(hostname)) {
      return this.cache.get(hostname);
    }
    
    // 检查是否正在请求
    if (this.pending.has(hostname)) {
      return this.pending.get(hostname);
    }
    
    // 开始请求
    const promise = this.fetchAndCache(hostname);
    this.pending.set(hostname, promise);
    
    try {
      const result = await promise;
      this.cache.set(hostname, result);
      return result;
    } finally {
      this.pending.delete(hostname);
    }
  }
  
  async fetchAndCache(hostname) {
